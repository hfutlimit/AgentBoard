# AgentBoard 配置
AGENTBOARD_DB_URL=sqlite:///./agentboard.db
# MariaDB 示例：mysql+pymysql://user:password@host:3306/agentboard

# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
AGENTBOARD_SECRET=replace-with-at-least-32-random-bytes

# 默认 30 天；缩短此值可降低长期 Token 泄漏风险。
AGENTBOARD_TOKEN_TTL_SECONDS=2592000
AGENTBOARD_REQUIRE_AUTH=1
AGENTBOARD_ALLOW_REGISTRATION=0
