# ===== AgentBoard MCP 服务环境变量（复制为 .env 后修改）=====
# 必须与 WebAPI 使用【相同】的 AGENTBOARD_SECRET。

AGENTBOARD_ENV=production

# 必须与 WebAPI 的 AGENTBOARD_SECRET 完全一致
AGENTBOARD_SECRET=__CHANGE_ME_TO_64_HEX_CHARS__

# 传输方式：http = Streamable HTTP（供远程 MCP 客户端 / IIS 反代）
AGENTBOARD_MCP_TRANSPORT=http
AGENTBOARD_MCP_HOST=127.0.0.1
AGENTBOARD_MCP_PORT=8001
AGENTBOARD_MCP_PATH=/mcp

# MCP 端点本身是否要求 Token（一般保持 0，由 IIS 控制暴露面）
AGENTBOARD_MCP_REQUIRE_AUTH=0

# MCP 调 AgentBoard REST API 的地址（走本机 WebAPI 服务，不经 IIS）
AGENTBOARD_API_URL=http://127.0.0.1:8000

# MCP 调用 API 所用的长期凭证（API Key，abk_ 开头）。
# 运行 webapi 包里的 make-mcp-token.py 生成后填入此处。
AGENTBOARD_MCP_TOKEN=__PASTE_MCP_API_KEY_HERE__

AGENTBOARD_TOKEN_TTL_SECONDS=2592000
