# ===== AgentBoard WebAPI 环境变量（复制为 .env 后修改）=====
# 注意：等号两侧不要有空格；值含特殊字符请勿加引号。

# 运行模式：production 会强制校验下方安全项；development 仅本地开发用
AGENTBOARD_ENV=production

# 强随机密钥（>=32 字节）。生产必须，可用：openssl rand -hex 32
AGENTBOARD_SECRET=__CHANGE_ME_TO_64_HEX_CHARS__

# 统一保护 REST 业务端点（生产必须 =1）
AGENTBOARD_REQUIRE_AUTH=1

# 数据库（MariaDB/MySQL）。先建库建用户，再填这里。
AGENTBOARD_DB_URL=mysql+pymysql://agentboard:agentboard@127.0.0.1:3306/agentboard

# CORS 白名单（生产不允许 *）。填 IIS 公网域名（含 https://）。
AGENTBOARD_CORS_ORIGINS=https://agentboard.example.com

# 限流：每 IP 每窗口请求数
AGENTBOARD_RATE_LIMIT=300
AGENTBOARD_RATE_WINDOW=60

# Token 有效期（秒），默认 30 天
AGENTBOARD_TOKEN_TTL_SECONDS=2592000

# 是否允许自助注册（首次建管理员时临时 =1，之后改回 0）
AGENTBOARD_ALLOW_REGISTRATION=0

# 监听端口（run-webapi.ps1 读取；IIS 反代默认 8000）
AGENTBOARD_API_PORT=8000
